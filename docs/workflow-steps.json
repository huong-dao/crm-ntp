    {
      "id": "0.1",
      "title": "Mua/đăng ký VPS (Ubuntu 22.04+, RAM ≥ 2GB)",
      "role": "DevOps",
      "type": "manual",
      "depends_on": [],
      "reference": "docs/04-server/01-server-setup.md",
      "actions": [
        "Chọn nhà cung cấp: Vultr, DigitalOcean, Contabo, Viettel IDC",
        "Chọn Ubuntu 22.04 LTS, RAM ≥ 2GB, 20GB disk",
        "Ghi nhận IP server và root password/SSH key",
        "Cập nhật docs/project-config.json: server_ip"
      ],
      "verify": ["SSH kết nối được: ssh root@SERVER_IP"],
      "deliverables": ["server_ip trong project-config.json"]
    },
    {
      "id": "0.2",
      "title": "Cài Node.js 20 LTS, pnpm",
      "role": "DevOps",
      "type": "hybrid",
      "depends_on": ["0.1"],
      "reference": "docs/04-server/01-server-setup.md#bước-4",
      "actions": [
        "SSH vào server",
        "apt update && apt upgrade -y",
        "curl -fsSL https://deb.nodesource.com/setup_20.x | bash -",
        "apt install -y nodejs",
        "npm install -g pnpm",
        "Verify: node -v, pnpm -v"
      ],
      "verify": ["node -v hiển thị v20.x", "pnpm -v hiển thị version"],
      "deliverables": []
    },
    {
      "id": "0.3",
      "title": "Cài PostgreSQL 15+",
      "role": "DevOps",
      "type": "hybrid",
      "depends_on": ["0.2"],
      "reference": "docs/04-server/01-server-setup.md#bước-5",
      "actions": [
        "apt install -y postgresql postgresql-contrib",
        "systemctl enable postgresql && systemctl start postgresql",
        "Verify: systemctl status postgresql"
      ],
      "verify": ["PostgreSQL active (running)"],
      "deliverables": []
    },
    {
