      "role": "DevOps",
      "type": "hybrid",
      "depends_on": ["0.3"],
      "reference": "docs/04-server/02-database-setup.md",
      "actions": [
        "sudo -u postgres psql",
        "CREATE USER ntp_user WITH PASSWORD '...'",
        "CREATE DATABASE ntp_members OWNER ntp_user",
        "GRANT ALL PRIVILEGES",
        "Test: psql -U ntp_user -d ntp_members -h localhost"
      ],
      "verify": ["Kết nối DB thành công"],
      "deliverables": ["DATABASE_URL cho .env"]
    },
    {
