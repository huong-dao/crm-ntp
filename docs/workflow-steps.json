      "type": "hybrid",
      "depends_on": ["0.4"],
      "reference": "docs/04-server/01-server-setup.md#bước-8",
      "actions": [
        "ufw allow OpenSSH",
        "ufw allow 'Nginx Full'",
        "ufw enable",
        "ufw status"
