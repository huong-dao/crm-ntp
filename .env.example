# Database (MySQL — DirectAdmin / hosting)
# Thêm ?charset=utf8mb4 để tiếng Việt
DATABASE_URL="mysql://USER:PASSWORD@localhost:3306/DATABASE_NAME?charset=utf8mb4"

# NextAuth (v5 dùng AUTH_SECRET; NEXTAUTH_SECRET vẫn được hỗ trợ)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="https://thamvieng.ntpchurch.org"
NEXTAUTH_URL="https://thamvieng.ntpchurch.org"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ⚠️ KHÔNG đặt NODE_ENV ở đây — Next.js tự set (dev/build/production).
# NODE_ENV=development trong .env gây lỗi build /_global-error trên server.
