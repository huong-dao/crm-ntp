# Database (PostgreSQL on server)
DATABASE_URL="postgresql://ntp_user:password@localhost:5432/ntp_members"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ⚠️ KHÔNG đặt NODE_ENV ở đây — Next.js tự set (dev/build/production).
# NODE_ENV=development trong .env gây lỗi build /_global-error trên server.
